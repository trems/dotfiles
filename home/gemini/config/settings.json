{
  "experimental": {
    "enableAgents": true,
    "plan": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true
  },
  "general": {
    "vimMode": true,
    "previewFeatures": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "checkpointing": {
      "enabled": true
    }
  },
  "context": {
    "includeDirectories": [
      "~/.gemini/extensions/pickle-rick"
    ],
    "fileName": [
      "AGENTS.md",
      "CONTEXT.md",
      "GEMINI.md"
    ]
  },
  "ui": {
    "showStatusInTitle": true,
    "footer": {
      "hideContextPercentage": false
    },
    "showMemoryUsage": true,
    "showCitations": true,
    "showModelInfoInChat": true,
    "loadingPhrases": "tips",
    "useAlternateBuffer": true
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "model": {
    "name": ""
  }
}